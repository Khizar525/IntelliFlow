# ── Orchestrator (Khizar) ──────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here
JWT_ISSUER=IntelliFlow
JWT_AUDIENCE=IntelliFlowClients

# ── Supabase (Hassan) ──────────────────────────
SUPABASE_DB_CONNECTION=Host=...;Port=5432;Database=postgres;Username=...;Password=...
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_BLOB_CONTAINER=reports

# ── Email SMTP (Shamraiz) ─────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM=noreply@intelliflow.app

# ── Blockchain (Shamraiz) ─────────────────────
ALCHEMY_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_key_here
ETH_PRIVATE_KEY=your_sepolia_wallet_private_key
AUDIT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ── Service URLs (used by Orchestrator (Khizar)) ───────
RESEARCH_SERVICE_URL=http://researchsummarizer:5001
REPORTER_SERVICE_URL=http://reporter:5002
NOTIFIER_SERVICE_URL=http://notifier:5003

# ── OpenRouter (Humza) ──────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free
ASPNETCORE_URLS=http://+:8080
